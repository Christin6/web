---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Pull the collection using the modern Loader framework
const blogEntries = await getCollection('blog');
const chronologicalEntries = blogEntries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout pageTitle="Maricel C - Home">
  <section class="intro-block">
    <img src="../icons/computer_explorer_2k-4.png" />
    <h1>Welcome 👋</h1>
    <p>Documenting deep-dives into application stacks, system backends, and biomechanics.</p>
  </section>

  <div class="feed-grid">
    {chronologicalEntries.map((post) => (
      <article class="feed-card">
        <h2 class="card-title">
          <a href={`./blog/${post.id}`}>{post.data.title}</a>
        </h2>
        <p class="card-desc">{post.data.description}</p>
        <div class="badge-row">
          {post.data.tags.map((tag) => (
            <a href={`./tags/${tag}`} class="tag-badge">#{tag}</a>
          ))}
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
